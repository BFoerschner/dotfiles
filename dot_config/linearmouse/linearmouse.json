{
  "$schema" : "https:\/\/schema.linearmouse.app\/0.10.4",
  "schemes" : [
    {
      "buttons" : {
        "universalBackForward" : true
      },
      "if" : {
        "device" : {
          "category" : "mouse",
          "productID" : "0xc1",
          "productName" : "Razer Viper V3 Pro",
          "vendorID" : "0x1532"
        }
      },
      "pointer" : {
        "acceleration" : 0.9,
        "disableAcceleration" : true,
        "redirectsToScroll" : false,
        "speed" : "unset"
      },
      "scrolling" : {
        "acceleration" : {
          "vertical" : 1
        },
        "distance" : {
          "vertical" : 8
        },
        "modifiers" : {
          "vertical" : {
            "command" : {
              "type" : "preventDefault"
            },
            "control" : {
              "type" : "zoom"
            },
            "option" : {
              "scale" : 2,
              "type" : "changeSpeed"
            },
            "shift" : {
              "type" : "alterOrientation"
            }
          }
        },
        "reverse" : {
          "vertical" : true
        },
        "speed" : {
          "vertical" : 0
        }
      }
    }
  ]
}