#!/bin/bash
set -euo pipefail

RAMDIR="/run/user/$(id -u)/secrets"
PIDFILE="$RAMDIR/.watchdog.pid"
LOCKFILE="$RAMDIR/.sessions"

# Kill watchdog
if [[ -f "$PIDFILE" ]]; then
    kill "$(cat "$PIDFILE")" 2>/dev/null || true
fi

# Remove symlinks
rm -f "$HOME/.supermaven/config.json" 2>/dev/null || true

# Unmount tmpfs — all decrypted data, pidfile, and lockfile vanish from RAM
if mountpoint -q "$RAMDIR" 2>/dev/null; then
    sudo umount "$RAMDIR"
    rmdir "$RAMDIR" 2>/dev/null || true
fi

echo "Secrets locked."
