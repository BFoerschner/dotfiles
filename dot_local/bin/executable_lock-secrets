#!/bin/bash
set -euo pipefail

RAMDIR="/dev/shm/.secrets-$(id -u)"
PIDFILE="$RAMDIR/.watchdog.pid"

# Kill watchdog
if [[ -f "$PIDFILE" ]]; then
    kill "$(cat "$PIDFILE")" 2>/dev/null || true
fi

# Remove symlinks
rm -f "$HOME/.supermaven/config.json" 2>/dev/null || true

# Remove secrets directory — on tmpfs, so no disk persistence
# Note: pages are freed when all open fds are closed
rm -rf "$RAMDIR" 2>/dev/null || true

echo "Secrets locked."
