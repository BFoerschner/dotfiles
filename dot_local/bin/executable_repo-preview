#!/usr/bin/env bash
set -uo pipefail

export PATH="$HOME/.local/share/mise/shims:$PATH"

INPUT="$1"
PROVIDER="${INPUT%%:*}"
REPO="${INPUT#*:}"

case "$PROVIDER" in
  github)
    readme=$(gh api "repos/$REPO/readme" --jq '.content' 2>/dev/null | base64 -d 2>/dev/null)
    if [[ -n "$readme" ]]; then
      echo "$readme" | glow -s dark - 2>/dev/null && exit 0
    fi
    gh repo view "$REPO" 2>/dev/null && exit 0
    ;;
  gitea)
    readme=$(tea api "/repos/$REPO/readme" 2>/dev/null | jq -r '.content // empty' 2>/dev/null | base64 -d 2>/dev/null)
    if [[ -n "$readme" ]]; then
      echo "$readme" | glow -s dark - 2>/dev/null && exit 0
    fi
    tea api "/repos/$REPO" 2>/dev/null \
      | jq -r '"# " + .full_name + "\n\n" + (.description // "No description") + "\n\n⭐ " + (.stars_count // 0 | tostring) + "  🍴 " + (.forks_count // 0 | tostring) + "  " + (.language // "")' 2>/dev/null \
      | glow -s dark - 2>/dev/null && exit 0
    ;;
esac

echo "$REPO"
