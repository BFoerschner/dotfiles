#!/bin/bash
set -euo pipefail
umask 077

SECRETS_DIR="$HOME/.config/secrets"
RAMDIR="/dev/shm/.secrets-$(id -u)"
TOKEN_FILE="$RAMDIR/.claude-token"
PIDFILE="$RAMDIR/.watchdog.pid"

for cmd in sops gpg jq; do
    if ! command -v "$cmd" > /dev/null 2>&1; then
        echo "$cmd not found on PATH." >&2
        exit 1
    fi
done

# Create a private directory on /dev/shm (already tmpfs — RAM only, no disk)
if [[ -L "$RAMDIR" ]]; then
    echo "RAMDIR is a symlink, aborting." >&2
    exit 1
fi
if [[ ! -d "$RAMDIR" ]]; then
    mkdir -m 700 "$RAMDIR"
fi
# Verify ownership and permissions whether newly created or pre-existing
_owner="$(stat -c '%u' "$RAMDIR")"
_mode="$(stat -c '%a' "$RAMDIR")"
if [[ "$_owner" != "$(id -u)" || "$_mode" != "700" ]]; then
    echo "RAMDIR has wrong ownership or permissions, aborting." >&2
    exit 1
fi

# Decrypt combined secrets (single GPG operation)
tmp="$(mktemp "$RAMDIR/.tmp.XXXXXX")"
trap 'rm -f "$tmp"' EXIT
sops -d "$SECRETS_DIR/secrets.sops.json" > "$tmp"

# Extract token
jq -jr '.token' "$tmp" > "$TOKEN_FILE"

# Extract supermaven config
jq '.supermaven' "$tmp" > "$RAMDIR/supermaven.json"

rm -f "$tmp"
trap - EXIT

# Symlink to expected location
mkdir -p "$HOME/.supermaven"
ln -sf "$RAMDIR/supermaven.json" "$HOME/.supermaven/config.json"

# Start watchdog (5 min) if not already running
if ! kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null || \
   [[ "$(ps -p "$(cat "$PIDFILE" 2>/dev/null)" -o comm= 2>/dev/null)" != "secrets-watchdo"* ]]; then
    nohup secrets-watchdog 300 > /dev/null 2>&1 &
    echo $! > "$PIDFILE"
fi

echo "Secrets unlocked."
