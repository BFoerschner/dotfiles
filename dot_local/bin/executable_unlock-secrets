#!/bin/bash
set -euo pipefail
umask 077

# shellcheck source=secrets-platform
source secrets-platform

SECRETS_DIR="$HOME/.config/secrets"
TOKEN_FILE="$SECRETS_RAMDIR/.claude-token"

for cmd in sops gpg jq; do
    if ! command -v "$cmd" > /dev/null 2>&1; then
        echo "$cmd not found on PATH." >&2
        exit 1
    fi
done

# Create a private RAM-backed directory
_secrets_create_ramdir

# Decrypt combined secrets (single GPG operation)
tmp="$(mktemp "$SECRETS_RAMDIR/.tmp.XXXXXX")"
trap 'rm -f "$tmp"' EXIT
sops -d "$SECRETS_DIR/secrets.sops.json" > "$tmp"

# Extract token
jq -jr '.token' "$tmp" > "$TOKEN_FILE"

# Extract supermaven config
jq '.supermaven' "$tmp" > "$SECRETS_RAMDIR/supermaven.json"

rm -f "$tmp"
trap - EXIT

# Symlink to expected location
mkdir -p "$HOME/.supermaven"
ln -sf "$SECRETS_RAMDIR/supermaven.json" "$HOME/.supermaven/config.json"

echo "Secrets unlocked."
