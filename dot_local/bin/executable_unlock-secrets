#!/bin/bash
set -euo pipefail
umask 077

SECRETS_DIR="$HOME/.config/secrets"

for cmd in sops gpg; do
    if ! command -v "$cmd" > /dev/null 2>&1; then
        echo "$cmd not found on PATH." >&2
        exit 1
    fi
done

if ! gpg --card-status > /dev/null 2>&1; then
    echo "YubiKey not detected, cannot unlock." >&2
    exit 1
fi

decrypt_secret() {
    local src="$1" dest="$2" dir
    dir="$(dirname "$dest")"
    mkdir -p "$dir"
    tmp="$(mktemp "$dir/.tmp.XXXXXX")"
    trap 'rm -f "$tmp"' RETURN
    sops -d "$src" > "$tmp"
    mv -f "$tmp" "$dest"
}

decrypt_secret "$SECRETS_DIR/claude_credentials.sops.json" "$HOME/.claude/.credentials.json"
decrypt_secret "$SECRETS_DIR/supermaven.sops.json" "$HOME/.supermaven/config.json"

echo "Secrets unlocked."
