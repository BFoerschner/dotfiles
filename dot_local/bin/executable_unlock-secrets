#!/bin/bash
set -euo pipefail
umask 077

SECRETS_DIR="$HOME/.config/secrets"
RAMDIR="/run/user/$(id -u)/secrets"
TOKEN_FILE="$RAMDIR/.claude-token"
PIDFILE="$RAMDIR/.watchdog.pid"

for cmd in sops gpg; do
    if ! command -v "$cmd" > /dev/null 2>&1; then
        echo "$cmd not found on PATH." >&2
        exit 1
    fi
done

# Create a tmpfs-backed directory for decrypted secrets
if ! mountpoint -q "$RAMDIR" 2>/dev/null; then
    mkdir -p "$RAMDIR"
    # Verify not a symlink before mounting
    if [[ -L "$RAMDIR" ]]; then
        echo "RAMDIR is a symlink, aborting." >&2
        exit 1
    fi
    sudo mount -t tmpfs -o size=1m,mode=0700,uid="$(id -u)",gid="$(id -g)",noexec,nosuid,nodev tmpfs "$RAMDIR"
fi

decrypt_secret() {
    local src="$1" dest="$2" dir tmp
    dir="$(dirname "$dest")"
    mkdir -p "$dir"
    tmp="$(mktemp "$dir/.tmp.XXXXXX")"
    trap 'rm -f "$tmp"' RETURN
    sops -d "$src" > "$tmp"
    mv -f "$tmp" "$dest"
}

# Claude Code token
decrypt_secret "$SECRETS_DIR/claude_token.sops.json" "$RAMDIR/.claude-token.json"
# Extract just the token value
python3 -c "import json,sys;print(json.load(open(sys.argv[1]))['token'],end='')" "$RAMDIR/.claude-token.json" > "$TOKEN_FILE"
rm -f "$RAMDIR/.claude-token.json"

# Supermaven credentials
decrypt_secret "$SECRETS_DIR/supermaven.sops.json" "$RAMDIR/supermaven.json"

# Symlink to expected location
mkdir -p "$HOME/.supermaven"
ln -sf "$RAMDIR/supermaven.json" "$HOME/.supermaven/config.json"

# Start watchdog (5 min) if not already running
if ! kill -0 "$(cat "$PIDFILE" 2>/dev/null)" 2>/dev/null || \
   [[ "$(ps -p "$(cat "$PIDFILE" 2>/dev/null)" -o comm= 2>/dev/null)" != "secrets-watchdo"* ]]; then
    nohup secrets-watchdog 300 > /dev/null 2>&1 &
    echo $! > "$PIDFILE"
fi

echo "Secrets unlocked."
