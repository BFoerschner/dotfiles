#!/bin/bash
# secrets-platform — shared helper library for cross-platform RAM-backed secrets
# Source this file; do not execute it directly.
#
# Exports:
#   SECRETS_PLATFORM   — container, linux, macos
#   SECRETS_RAMDIR     — platform-appropriate path for RAM-backed secrets
#   _secrets_create_ramdir   — create the RAM-backed directory
#   _secrets_destroy_ramdir  — destroy the RAM-backed directory (idempotent)
#   _secrets_stat_owner      — portable stat: print numeric owner UID
#   _secrets_stat_mode       — portable stat: print octal permission mode
#
# Security note (macOS swap risk — accepted tradeoff):
#   On macOS, the kernel could theoretically swap RAM disk pages to disk under
#   extreme memory pressure. This is the same risk any process holding secrets
#   in memory faces, and secrets are tiny (~few KB). This is an intentional
#   tradeoff: RAM disk still prevents secrets from landing in a persistent
#   filesystem and survives reboot cleanly.

# --- Platform detection (first match wins) ---

_secrets_uid="$(id -u)"

if [[ -e /.dockerenv ]] || [[ -e /run/.containerenv ]]; then
    SECRETS_PLATFORM="container"
    SECRETS_RAMDIR="/dev/shm/.secrets-${_secrets_uid}"
elif [[ "$(uname -s)" == "Linux" ]]; then
    SECRETS_PLATFORM="linux"
    SECRETS_RAMDIR="/dev/shm/.secrets-${_secrets_uid}"
elif [[ "$(uname -s)" == "Darwin" ]]; then
    SECRETS_PLATFORM="macos"
    SECRETS_RAMDIR="/tmp/.secrets-ramdisk-${_secrets_uid}"
else
    echo "secrets-platform: unsupported OS '$(uname -s)'" >&2
    return 1 2>/dev/null || exit 1
fi

# --- Portable stat wrappers ---

_secrets_stat_owner() {
    local target="$1"
    # GNU stat
    if stat -c '%u' "$target" 2>/dev/null; then
        return
    fi
    # BSD stat (macOS)
    stat -f '%u' "$target" 2>/dev/null
}

_secrets_stat_mode() {
    local target="$1"
    # GNU stat
    if stat -c '%a' "$target" 2>/dev/null; then
        return
    fi
    # BSD stat (macOS)
    stat -f '%Lp' "$target" 2>/dev/null
}

# --- RAM directory lifecycle ---

_secrets_create_ramdir() {
    # Symlink check (TOCTOU mitigation)
    if [[ -L "$SECRETS_RAMDIR" ]]; then
        echo "SECRETS_RAMDIR is a symlink, aborting." >&2
        return 1
    fi

    case "$SECRETS_PLATFORM" in
        container|linux)
            # /dev/shm is already tmpfs (RAM) — just mkdir
            if [[ ! -d /dev/shm ]]; then
                echo "/dev/shm not found — not a supported Linux environment." >&2
                return 1
            fi
            if [[ ! -d "$SECRETS_RAMDIR" ]]; then
                mkdir -m 700 "$SECRETS_RAMDIR"
            fi
            ;;
        macos)
            if mount | grep -q " on ${SECRETS_RAMDIR} "; then
                # Already mounted — force-detach stale mount first
                local stale_dev
                stale_dev="$(mount | grep " on ${SECRETS_RAMDIR} " | awk '{print $1}')"
                umount -f "$SECRETS_RAMDIR" 2>/dev/null || true
                hdiutil detach "$stale_dev" -force 2>/dev/null || true
                rmdir "$SECRETS_RAMDIR" 2>/dev/null || true
            fi
            mkdir -p "$SECRETS_RAMDIR"
            chmod 700 "$SECRETS_RAMDIR"
            local device
            device="$(hdiutil attach -nomount ram://$((2 * 1024 * 2)))"
            device="$(echo "$device" | xargs)"  # trim whitespace
            newfs_hfs -M 700 "$device" >/dev/null 2>&1
            mount -t hfs -o nobrowse,nodev,nosuid "$device" "$SECRETS_RAMDIR"
            chmod 700 "$SECRETS_RAMDIR"
            echo "$device" > "$SECRETS_RAMDIR/.device"
            ;;
    esac

    # Verify ownership and permissions
    local owner mode
    owner="$(_secrets_stat_owner "$SECRETS_RAMDIR")"
    mode="$(_secrets_stat_mode "$SECRETS_RAMDIR")"
    if [[ "$owner" != "$_secrets_uid" || "$mode" != "700" ]]; then
        echo "SECRETS_RAMDIR has wrong ownership or permissions, aborting." >&2
        return 1
    fi
}

_secrets_destroy_ramdir() {
    case "$SECRETS_PLATFORM" in
        container|linux)
            rm -rf "$SECRETS_RAMDIR" 2>/dev/null || true
            ;;
        macos)
            if [[ -f "$SECRETS_RAMDIR/.device" ]]; then
                local device
                device="$(cat "$SECRETS_RAMDIR/.device")"
                umount -f "$SECRETS_RAMDIR" 2>/dev/null || true
                hdiutil detach "$device" -force 2>/dev/null || true
            elif mount | grep -q " on ${SECRETS_RAMDIR} "; then
                # .device file gone but still mounted — force-detach
                local dev
                dev="$(mount | grep " on ${SECRETS_RAMDIR} " | awk '{print $1}')"
                umount -f "$SECRETS_RAMDIR" 2>/dev/null || true
                hdiutil detach "$dev" -force 2>/dev/null || true
            fi
            rmdir "$SECRETS_RAMDIR" 2>/dev/null || true
            ;;
    esac
}
