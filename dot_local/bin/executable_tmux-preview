#!/usr/bin/env bash
set -euo pipefail

session="$1"
tmux has-session -t "$session" 2>/dev/null || { echo "Session not found"; exit 1; }

# Colors
MAGENTA='\033[1;35m'
CYAN='\033[1;36m'
GREEN='\033[1;32m'
GRAY='\033[0;37m'
RESET='\033[0m'

printf "${MAGENTA}%s${RESET}\n\n" "$session"

tmux list-windows -t "$session" -F '#{window_index}:#{window_name}:#{window_active}' 2>/dev/null | while IFS=: read -r idx name active; do
  if [[ "$active" == "1" ]]; then
    printf "${GREEN}* %s:%s${RESET}\n" "$idx" "$name"
  else
    printf "${CYAN}  %s:%s${RESET}\n" "$idx" "$name"
  fi

  tmux list-panes -t "${session}:${idx}" -F '#{pane_current_command}:#{pane_current_path}' 2>/dev/null | while IFS=: read -r cmd path; do
    path="${path/#$HOME/\~}"
    [[ ${#path} -gt 30 ]] && path="...${path: -27}"
    printf "${GRAY}    %s (%s)${RESET}\n" "$cmd" "$path"
  done
done
