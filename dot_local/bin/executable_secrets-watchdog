#!/bin/bash
# Background watchdog: locks secrets if no SSH sessions remain.
# Spawned by unlock-secrets, exits after locking or if secrets are already gone.
set -euo pipefail
umask 077

INTERVAL="${1:-300}"
RAMDIR="/dev/shm/.secrets-$(id -u)"
LOCKFILE="$RAMDIR/.sessions"

while true; do
    sleep "$INTERVAL"

    # Nothing to protect — exit
    if [[ ! -d "$RAMDIR" ]]; then
        exit 0
    fi

    # Check if any tracked sessions are still alive, prune dead ones
    live_pids=()
    if [[ -f "$LOCKFILE" ]]; then
        while IFS= read -r pid; do
            if kill -0 "$pid" 2>/dev/null; then
                live_pids+=("$pid")
            fi
        done < "$LOCKFILE"
        # Rewrite lockfile with only live PIDs
        if [[ ${#live_pids[@]} -gt 0 ]]; then
            printf '%s\n' "${live_pids[@]}" > "$LOCKFILE"
        else
            : > "$LOCKFILE"
        fi
    fi

    if [[ ${#live_pids[@]} -eq 0 ]]; then
        lock-secrets 2>/dev/null
        exit 0
    fi
done
